"""Graph-shaped idiomatic conversion seeds — the tier with real idiom headroom.

Unlike the standalone-function seeds (where idiomatic Jac ≈ the py2jac transpile,
similarity ~0.97, so DPO has nothing to move), these tasks operate on graphs: the
Python is a dict+stack traversal, but idiomatic Jac builds nodes/edges and spawns a
walker. Measured idiomatic-vs-transpile similarity ~0.26 (vs 0.97) — a large idiom
axis. The function signature stays single-dict-arg so the behavioral eval harness
(eval_probe.jac) drives them unchanged.

Reads the validated task set srccurrent/jacgen/graph_data/train.json and APPENDS one
SFT example per task to dataset/conversion/sft.jsonl, re-validating each by running
the idiomatic Jac on the task's first test case. Run AFTER the idiomatic batches:
    jac run srccurrent/jacgen/graph_seeds.jac

Generated by the validated authoring harness (all 8 tasks pass jac run on every case).
"""

import json;
import from writer { make_sft_example, append_jsonl, run_jac }
import from pathlib { Path }
import from typing { Any }

glob TASKS: str = "srccurrent/jacgen/graph_data/train.json";
glob SFT_PATH: str = "dataset/conversion/sft.jsonl";


with entry {
    p = Path(TASKS);
    if not p.exists() {
        print("missing " + TASKS + " -- run the graph authoring harness first");
    } else {
        tasks: list = list(json.loads(p.read_text()));
        written: int = 0;
        failed: int = 0;
        for t in tasks {
            name: str = str(t["name"]);
            py: str = str(t["py"]);
            jac: str = str(t["jac"]);
            cases: list = list(t["cases"]);
            difficulty: str = str(t["difficulty"]);
            first: dict = dict(cases[0]);
            inp = first["input"];
            expected: str = str(first["output"]);

            # store self-running jac (def + walker + node + a with-entry demo) so it
            # re-validates like every other seed; the eval harness strips with-entry.
            demo: str = "with entry {\n    print(" + name + "(" + repr(inp) + "));\n}";
            jac_full: str = jac + "\n\n" + demo;
            (code, sout, serr) = run_jac(jac_full);
            if code != 0 or sout.strip() != expected {
                failed += 1;
                print("  FAIL " + name + ": rc=" + str(code) + " out=" + sout.strip() + " want=" + expected);
                continue;
            }

            ex: dict = make_sft_example(py, jac_full, difficulty, expected,
                                        "generated_graph", "claude-code-graph");
            append_jsonl(SFT_PATH, ex);
            written += 1;
        }
        print("graph seeds: " + str(written) + " appended, " + str(failed)
            + " failed -> " + SFT_PATH);
    }
}
