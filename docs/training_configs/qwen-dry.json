{
    "adapter_path": "adapters/qwen-dry",
    "batch_size": 2,
    "clear_cache_threshold": 0,
    "config": "configs/lora.yaml",
    "data": "dataset/mlx",
    "fine_tune_type": "lora",
    "grad_accumulation_steps": 1,
    "grad_checkpoint": false,
    "iters": 30,
    "learning_rate": 2e-05,
    "lora_parameters": {
        "rank": 16,
        "scale": 2.0,
        "dropout": 0.05
    },
    "lr_schedule": {
        "name": "cosine_decay",
        "warmup": 60,
        "arguments": [
            2e-05,
            600,
            1e-06
        ]
    },
    "mask_prompt": false,
    "max_seq_length": 2048,
    "model": "models/qwen-q4",
    "num_layers": 16,
    "optimizer": "adam",
    "optimizer_config": {
        "adam": {},
        "adamw": {},
        "muon": {},
        "sgd": {},
        "adafactor": {}
    },
    "project_name": null,
    "report_to": null,
    "resume_adapter_file": null,
    "save_every": 100,
    "seed": 42,
    "steps_per_eval": 50,
    "steps_per_report": 10,
    "test": false,
    "test_batches": 500,
    "train": true,
    "val_batches": 20
}