% Jaseci/UMich beamer theme replicating JaseciPresentation2.pdf chrome.
% Geometry measured from a 150dpi render of page 2 (fractions of 160x90mm page).
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jaseci-theme}

\RequirePackage{tikz}
\RequirePackage{helvet}
\renewcommand{\familydefault}{\sfdefault}

% Colors sampled from the PDF render
\definecolor{jasecidark}{HTML}{ED4834}   % left accent rect + page-number square
\definecolor{jaseciorange}{HTML}{EF6136} % right accent rect + footer bar
\definecolor{ink}{HTML}{212121}
\definecolor{inkmuted}{HTML}{5A5A5A}
\definecolor{chartblue}{HTML}{2F6FBF}    % validated categorical partner for the orange
\definecolor{gridgray}{HTML}{DDDDDD}

\mode<presentation>
\setbeamertemplate{navigation symbols}{}
\usefonttheme{professionalfonts}

\setbeamercolor{normal text}{fg=ink}
\setbeamercolor{structure}{fg=jaseciorange}
\setbeamercolor{alerted text}{fg=jasecidark}
\setbeamerfont{alerted text}{series=\normalfont}
\setbeamercolor{frametitle}{fg=ink}
\setbeamerfont{frametitle}{size=\large,series=\bfseries}
\setbeamerfont{block title}{series=\normalfont}
\setbeamercolor{banner}{bg=jasecidark,fg=white}
\setbeamercolor{itemize item}{fg=jaseciorange}
\setbeamercolor{itemize subitem}{fg=jaseciorange}
\setbeamertemplate{itemize item}{\raisebox{0.16ex}{\scriptsize$\blacksquare$}}
\setbeamertemplate{itemize subitem}{--}

% ---- content-slide chrome (page-2 replica) ----
% accent bars: x 0-7.04mm dark, 7.04-16.96mm orange, height 1.71mm
% footer bar: x 112.85-151.36mm, y 82.11-87.09mm, orange, white "JASECI"
% page-number square: x 151.36-160mm, same y, dark, white number
% UMich logo: x 0-6.72mm, y 80.51-87.66mm
\setbeamertemplate{background}{%
  \begin{tikzpicture}[remember picture,overlay]
    \usebeamercolor{normal text}
    \fill[white] (current page.north west) rectangle (current page.south east);
    \fill[jasecidark]   ([xshift=0mm,yshift=0mm]current page.north west)
                        rectangle ([xshift=7.04mm,yshift=-1.71mm]current page.north west);
    \fill[jaseciorange] ([xshift=7.04mm]current page.north west)
                        rectangle ([xshift=16.96mm,yshift=-1.71mm]current page.north west);
    \fill[jaseciorange] ([xshift=112.85mm,yshift=-82.11mm]current page.north west)
                        rectangle ([xshift=151.36mm,yshift=-87.09mm]current page.north west);
    \fill[jasecidark]   ([xshift=151.36mm,yshift=-82.11mm]current page.north west)
                        rectangle ([xshift=160mm,yshift=-87.09mm]current page.north west);
    \node[anchor=center] at ([xshift=132.1mm,yshift=-84.6mm]current page.north west)
      {\fontsize{5.5}{5.5}\selectfont\color{white}\bfseries J\hspace{0.5em}A\hspace{0.5em}S\hspace{0.5em}E\hspace{0.5em}C\hspace{0.5em}I};
    \node[anchor=center] at ([xshift=155.68mm,yshift=-84.6mm]current page.north west)
      {\fontsize{6}{6}\selectfont\color{white}\insertframenumber};
    \node[anchor=north west,inner sep=0pt] at ([yshift=-80.51mm]current page.north west)
      {\includegraphics[height=7.15mm]{assets/img-005.png}};
  \end{tikzpicture}%
}

\setbeamertemplate{frametitle}{%
  \vspace{4.5mm}%
  {\usebeamerfont{frametitle}\usebeamercolor[fg]{frametitle}\insertframetitle\par}%
  \vspace{1mm}%
}
\setbeamertemplate{footline}{}
\setbeamersize{text margin left=10mm,text margin right=10mm}

\mode<all>
